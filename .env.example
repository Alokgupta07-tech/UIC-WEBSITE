# Supabase credentials (client-side safe / anon key)
# Find these in your Supabase project: Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Google sign-in only works after enabling the Google provider in
# Supabase Auth and adding the redirect URL for your app.
# For local development, add: http://localhost:8080/

# Public site URL (no trailing slash) — used for canonical URLs, sitemap, OG tags.
# In Vercel set this as a project env var (e.g. https://uic.example.com).
VITE_SITE_URL=https://your-domain.com
